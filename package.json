{
  "name": "simple-super-doc",
  "version": "0.2.0",
  "description": "Faithful DOCX renderer with exposed typed IR for building document editors",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "build:demo": "tsup src/index.ts --format iife --global-name SimpleDoc --outDir demo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["docx", "word", "renderer", "parser", "document", "ir"],
  "license": "MIT",
  "dependencies": {
    "fast-xml-parser": "^5.9.3",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
